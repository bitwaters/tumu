# Copy this file to .env.production and replace every CHANGE_ME value before deployment.

APP_IMAGE_TAG=local
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com/
DATA_ROOT=./data

POSTGRES_DB=site_management
POSTGRES_USER=site_user
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_HOST_PORT=5432

API_HOST_PORT=4000
WEB_HOST_PORT=8080
PUBLIC_API_BASE_URL=http://SERVER_HOSTNAME_OR_IP:4000
PUBLIC_WEB_BASE_URL=http://SERVER_HOSTNAME_OR_IP:8080
API_CORS_ORIGIN=http://SERVER_HOSTNAME_OR_IP:8080

S3_BUCKET=site-management
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS
JWT_TTL_HOURS=12
UPLOAD_MAX_BYTES=10485760
IDEMPOTENCY_TTL_HOURS=24

# Only required when intentionally running prisma:seed on an empty deployment.
# Use one shared initial password, or set SEED_ADMIN_PASSWORD and SEED_USER_PASSWORD separately.
SEED_DEMO_PASSWORD=CHANGE_ME_SEED_DEMO_PASSWORD

BACKUP_DIR=/var/backups/site-management

SMOKE_USERNAME=wang.supervisor
SMOKE_PASSWORD=CHANGE_ME_SMOKE_PASSWORD
