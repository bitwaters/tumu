{
  "name": "site-management-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "scripts": {
    "dev:web": "npm --workspace @site-management/web run dev",
    "build:web": "npm --workspace @site-management/web run build",
    "preview:web": "npm --workspace @site-management/web run preview",
    "typecheck:web": "npm --workspace @site-management/web run typecheck",
    "dev:api": "npm --workspace @site-management/api run dev",
    "build:api": "npm --workspace @site-management/api run build",
    "start:api": "npm --workspace @site-management/api run start",
    "test:api": "npm --workspace @site-management/api run test",
    "typecheck:api": "npm --workspace @site-management/api run typecheck",
    "db:generate": "npm --workspace @site-management/api run prisma:generate",
    "db:migrate": "npm --workspace @site-management/api run prisma:migrate",
    "db:seed": "npm --workspace @site-management/api run prisma:seed",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "prod:config": "docker compose --env-file .env.production -f infra/docker-compose.prod.yml config",
    "prod:init-env": "node scripts/prod/init-env.mjs",
    "prod:build": "docker compose --env-file .env.production -f infra/docker-compose.prod.yml build",
    "prod:up": "docker compose --env-file .env.production -f infra/docker-compose.prod.yml up -d",
    "prod:down": "docker compose --env-file .env.production -f infra/docker-compose.prod.yml down",
    "prod:status": "docker compose --env-file .env.production -f infra/docker-compose.prod.yml ps",
    "prod:preflight": "sh scripts/prod/preflight.sh",
    "prod:migrate": "sh scripts/prod/migrate.sh",
    "prod:smoke": "node scripts/prod/smoke.mjs",
    "test:prod-env": "node --test scripts/prod/init-env.test.mjs",
    "backup:db": "sh scripts/prod/backup-db.sh",
    "restore:db": "sh scripts/prod/restore-db.sh",
    "backup:objects": "sh scripts/prod/backup-objects.sh",
    "restore:objects": "sh scripts/prod/restore-objects.sh"
  }
}
